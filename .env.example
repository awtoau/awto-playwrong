# Shared persistent profile outside this workspace
PLAYWRIGHT_USER_DATA_DIR=~/ai-browser-profiles/ai-profile

# Optional profile name under ~/ai-browser-profiles/ (used when PLAYWRIGHT_USER_DATA_DIR is not set)
# PLAYWRIGHT_PROFILE_NAME=ai-profile

# Comma-separated sites to open for login/session reuse
PLAYWRIGHT_TARGET_URLS=https://www.apple.com/,https://accounts.google.com/

# Use installed Chrome channel by default
PLAYWRIGHT_CHANNEL=chrome

# Keep false when you need manual login
PLAYWRIGHT_HEADLESS=false
